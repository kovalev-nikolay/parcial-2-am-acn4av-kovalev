<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layoutHomeContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatsModeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_mode_all"
            android:textColor="@color/color_white"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatsPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/stats_period"
            android:textColor="@color/color_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/layoutStatsCircle"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="8dp">

            <com.kovalev.shottracker.BasketballProgressView
                android:id="@+id/imgStatsRing"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:contentDescription="@string/home_progress_ring_description" />

            <TextView
                android:id="@+id/tvAccuracyPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/home_accuracy_default"
                android:textColor="@color/color_white"
                android:textSize="58sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBasketballIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/home_basketball_icon"
                android:textSize="28sp" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/cardShotProgress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="7dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvShotsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/shots_label"
                    android:textColor="@color/color_white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShotsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shots_count"
                    android:textColor="@color/color_orange"
                    android:textSize="18sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/progressShotsContainer"
                android:layout_width="match_parent"
                android:layout_height="7dp">

                <View
                    android:id="@+id/viewProgressTrack"
                    android:layout_width="match_parent"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_progress_track" />

                <View
                    android:id="@+id/viewProgressFill"
                    android:layout_width="90dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_progress_fill" />
            </FrameLayout>
        </LinearLayout>

        <GridLayout
            android:id="@+id/layoutTrainingButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:columnCount="2"
            android:rowCount="2">

            <FrameLayout
                android:id="@+id/btnJuntos"
                style="@style/TrainingButtonStyle">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_circle_number"
                    android:gravity="center"
                    android:text="@string/home_star_icon"
                    android:textColor="@color/color_black"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="@string/mode_juntos"
                    android:textColor="@color/color_white"
                    android:textStyle="bold"
                    android:textSize="18sp" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnLibres"
                style="@style/TrainingButtonStyle">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_circle_number"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/color_black"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="@string/mode_libres"
                    android:textColor="@color/color_white"
                    android:textStyle="bold"
                    android:textSize="18sp" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnCampo"
                style="@style/TrainingButtonStyle">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_circle_number"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/color_black"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="@string/mode_campo"
                    android:textColor="@color/color_white"
                    android:textStyle="bold"
                    android:textSize="18sp" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnTres"
                style="@style/TrainingButtonStyle">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_circle_number"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/color_black"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="@string/mode_tres"
                    android:textColor="@color/color_white"
                    android:textStyle="bold"
                    android:textSize="18sp" />

            </FrameLayout>

        </GridLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/logout_margin"
        android:layout_marginEnd="@dimen/logout_margin"
        android:backgroundTint="@color/color_logout_background"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="@string/logout_action"
        android:textAllCaps="false"
        android:textColor="@color/color_logout_text"
        android:textSize="@dimen/logout_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="34dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/navStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@drawable/ic_nav_stats"
            android:contentDescription="@string/home_nav_stats_description" />

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/color_orange"
            android:gravity="center"
            android:text="@string/home_nav_icon"
            android:textColor="@color/color_black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/navTraining"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@drawable/ic_nav_ball"
            android:contentDescription="@string/home_nav_training_description" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>